<ruleset faction="CFM.S" ratingSystem="CLAN" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="formationRulesetSchema.xsd">

    <defaults>
        <echelon>%CLUSTER%</echelon>
        <rankSystem>%RANK_CUSTOM%</rankSystem>
        <rating>FL</rating>
    </defaults>

    <toc>
        <unitType>
            <option ifDateBetween="3060,">null,Mek,ProtoMek,Tank,VTOL,Infantry,BattleArmor,AeroSpaceFighter,Conventional Fighter</option>
            <option ifDateBetween="2870,3059">null,Mek,Tank,VTOL,Infantry,BattleArmor,AeroSpaceFighter,Conventional Fighter</option>
            <option ifDateBetween=",2869">null,Mek,Tank,VTOL,Infantry,AeroSpaceFighter,Conventional Fighter</option>
        </unitType>

        <echelon>
            <option ifUnitType="">%GALAXY%,%CLUSTER%</option>
            <option ifUnitType="Mek" ifDateBetween="2870,">%TRINARY%^,%TRINARY%,%BINARY%^,%BINARY%,%STAR%^,%STAR%</option>
            <option>%TRINARY%,%BINARY%,%STAR%</option>
        </echelon>

        <rating>
            <option ifUnitType="Tank|VTOL">SL:Second Line,PG:Garrison,Sol:Solahma</option>
            <option ifUnitType="Infantry" ifDateBetween="2900,">PG:Garrison,Sol:Solahma</option>
            <option ifUnitType="Infantry">PG:Garrison,Sol:Solahma</option>
            <option ifEschelon="%GALAXY%"></option>
            <option>Keshik,FL:Front Line,SL:Second Line,PG:Garrison,Sol:Solahma</option>
        </rating>

        <flags>
            <option ifUnitType="null|Mek|BattleArmor" ifEschelon="%TRINARY%|%BINARY%">mixedMekBA:Combined Mek/BA unit</option>
        </flags>
    </toc>

    <force echelon="%GALAXY%" eschName="Kindraa">
        <co>%GALAXY_CMDR%</co>

        <subforces>
            <subforce role="command" rating="Keshik"
                      unitType="Mek">%TRINARY%
            </subforce>
            <subforceOption>
                <option num="2" rating="FL">%CLUSTER%</option>
                <option num="3" rating="FL">%CLUSTER%</option>
            </subforceOption>
            <subforceOption>
                <option num="1" rating="SL">%CLUSTER%</option>
                <option num="2" rating="SL">%CLUSTER%</option>
            </subforceOption>
        </subforces>
    </force>

    <!-- Standard cluster includes one trinary each of Mek, AeroSpaceFighter, BA
    and an additional cluster of mixed Mek/BA-->
    <force echelon="%CLUSTER%" eschName="Cluster">
        <name ifRating="FL" ifWeightClass="A|H">Assault Cluster</name>
        <name ifRating="FL" ifWeightClass="M">Battle Cluster</name>
        <name ifRating="FL" ifWeightClass="L">Striker Cluster</name>
        <name ifRating="SL"
              ifWeightClass="A|H">Rear Guard Assault Cluster
        </name>
        <name ifRating="SL"
              ifWeightClass="M">Rear Guard Battle Cluster
        </name>
        <name ifRating="SL"
              ifWeightClass="L">Rear Guard Striker Cluster
        </name>
        <co>%STAR_COL%</co>

        <!-- Per-cluster-type weight targets (budget allocator). Kindraa Sainze (Clan Fire Mandrill
             Touman, Sarna) is the battle-hardened, aggressive Crusader Kindraa - the assault arm of
             the confederation. Heaviest Mek mix of any Fire Mandrill Kindraa, with a real assault
             core (picker rolls assault clusters). -->
        <!-- Targets pushed hard: Sainze's BA-paired clusters + fast cavalry Keshik make it run
             structurally light, so the budget targets over-aim heavy/assault to land it co-heaviest
             with Payne (verified: plain heavy targets under-delivered, H34/A10). -->
        <weightTarget ifWeightClass="A" unitType="Mek" spread="8">A:45,H:42,M:12,L:1</weightTarget>
        <weightTarget ifWeightClass="H" unitType="Mek" spread="8">A:28,H:50,M:20,L:2</weightTarget>
        <weightTarget ifWeightClass="M" unitType="Mek" spread="8">A:10,H:42,M:42,L:6</weightTarget>
        <weightTarget ifWeightClass="L" unitType="Mek" spread="8">A:3,H:24,M:45,L:28</weightTarget>
        <weightTarget unitType="AeroSpaceFighter" spread="8">A:0,H:40,M:42,L:18</weightTarget>
        <weightTarget unitType="Tank" spread="8">A:0,H:15,M:40,L:45</weightTarget>

        <weightClass>
            <option weight="2">A</option>
            <option weight="3">H</option>
            <option weight="2">M</option>
            <option weight="1">L</option>
        </weightClass>

        <subforces>
            <subforceOption ifWeightClass="H|A">
                <option weightClass="A" unitType="Mek"
                        weight="2">%TRINARY%
                </option>
                <option weightClass="H" unitType="Mek"
                        weight="3">%TRINARY%
                </option>
                <option weightClass="M" unitType="Mek"
                        weight="1">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" unitType="Mek"
                        weight="3">%TRINARY%
                </option>
                <option weightClass="M" unitType="Mek"
                        weight="3">%TRINARY%
                </option>
                <option weightClass="L" unitType="Mek"
                        weight="1">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="M" unitType="Mek">%TRINARY%</option>
                <option weightClass="L" unitType="Mek">%TRINARY%</option>
            </subforceOption>

            <subforceOption ifWeightClass="H|A">
                <option weightClass="H" unitType="AeroSpaceFighter"
                        weight="3">%TRINARY%
                </option>
                <option weightClass="M" unitType="AeroSpaceFighter"
                        weight="2">%TRINARY%
                </option>
                <option weightClass="L" unitType="AeroSpaceFighter"
                        weight="1">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" unitType="AeroSpaceFighter"
                        weight="2">%TRINARY%
                </option>
                <option weightClass="M" unitType="AeroSpaceFighter"
                        weight="3">%TRINARY%
                </option>
                <option weightClass="L" unitType="AeroSpaceFighter"
                        weight="2">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="H" unitType="AeroSpaceFighter"
                        weight="1">%TRINARY%
                </option>
                <option weightClass="M" unitType="AeroSpaceFighter"
                        weight="2">%TRINARY%
                </option>
                <option weightClass="L" unitType="AeroSpaceFighter"
                        weight="3">%TRINARY%
                </option>
            </subforceOption>

            <subforceOption ifRating="FL|Keshik">
                <option ifDateBetween="2870,"
                        unitType="BattleArmor">%TRINARY%
                </option>
                <option ifDateBetween=",2900" />
            </subforceOption>
            <subforceOption ifRating="SL|PG|Sol">
                <option unitType="Infantry" rating="Sol">%BINARY%</option>
                <option unitType="Infantry" rating="Sol">%TRINARY%</option>
            </subforceOption>

            <subforceOption ifWeightClass="H|A">
                <option weightClass="A" unitType="Mek"
                        flags="mixedMekBA" weight="2">%TRINARY%
                </option>
                <option weightClass="H" unitType="Mek"
                        flags="mixedMekBA" weight="3">%TRINARY%
                </option>
                <option weightClass="M" unitType="Mek"
                        flags="mixedMekBA" weight="1">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" unitType="Mek"
                        flags="mixedMekBA" weight="3">%TRINARY%
                </option>
                <option weightClass="M" unitType="Mek"
                        flags="mixedMekBA" weight="3">%TRINARY%
                </option>
                <option weightClass="L" unitType="Mek"
                        flags="mixedMekBA" weight="1">%TRINARY%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="M" unitType="Mek"
                        flags="mixedMekBA">%TRINARY%
                </option>
                <option weightClass="L" unitType="Mek"
                        flags="mixedMekBA">%TRINARY%
                </option>
            </subforceOption>
        </subforces>

        <attachedForces>
            <subforceOption>
                <option ifRating="FL|Keshik" unitType="Mek"
                        role="artillery"
                        name="Binary Artillery">%BINARY%
                </option>
                <option ifRating="SL|PG|Sol" unitType="Tank"
                        role="artillery"
                        name="Binary Artillery">%BINARY%
                </option>
                <option weight="11" />
            </subforceOption>
        </attachedForces>
    </force>

    <!-- Kindraa command trinary includes one nova. This rule does not
    meet the description in FMCC that all Meks in the command star
    have MASC, but selects faster units by adding the cavalry role.-->
    <force echelon="%TRINARY%" eschName="Trinary" ifUnitType="Mek"
           ifDateBetween="2870," ifRating="Keshik">
        <name>Trinary Kindraa [Command]</name>
        <co>%GALAXY_CMDR%</co>

        <ruleGroup>
            <weightClass>
                <option weight="3">A</option>
                <option weight="4">H</option>
                <option weight="2">M</option>
                <option weight="1">L</option>
            </weightClass>
        </ruleGroup>

        <subforces>
            <subforceOption ifWeightClass="A">
                <option weightClass="A" weight="2"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="H" weight="2"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="M" weight="1"
                        role="+cavalry">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="H">
                <option weightClass="A" weight="1"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="H" weight="3"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="M" weight="2"
                        role="+cavalry">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" weight="2"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="M" weight="2"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="L" weight="1"
                        role="+cavalry">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="H" weight="1"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="M" weight="2"
                        role="+cavalry">%STAR%
                </option>
                <option weightClass="L" weight="2"
                        role="+cavalry">%STAR%
                </option>
            </subforceOption>

            <subforceOption ifWeightClass="A">
                <option weightClass="A" weight="3"
                        role="-command">%STAR%
                </option>
                <option weightClass="H" weight="2"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="H">
                <option weightClass="A" weight="2"
                        role="-command">%STAR%
                </option>
                <option weightClass="H" weight="3"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="2"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" weight="2"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="3"
                        role="-command">%STAR%
                </option>
                <option weightClass="L" weight="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="H" weight="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="2"
                        role="-command">%STAR%
                </option>
                <option weightClass="L" weight="3"
                        role="-command">%STAR%
                </option>
            </subforceOption>

            <subforceOption ifWeightClass="A">
                <option weightClass="A" weight="3" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="H" weight="2" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="1" augmented="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="H">
                <option weightClass="A" weight="2" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="H" weight="3" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="2" augmented="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="M">
                <option weightClass="H" weight="2" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="3" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="L" weight="1" augmented="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
            <subforceOption ifWeightClass="L">
                <option weightClass="H" weight="1" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="M" weight="2" augmented="1"
                        role="-command">%STAR%
                </option>
                <option weightClass="L" weight="3" augmented="1"
                        role="-command">%STAR%
                </option>
            </subforceOption>
        </subforces>
    </force>
</ruleset>
